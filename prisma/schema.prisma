// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
    // output        = "../src/generated"
    // binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
    provider = "mongodb"
    url      = env("DATABASE_URL")
}

enum Region {
    americas
    asia
    europe
    sea
}

enum Platform {
    br1
    eun1
    euw1
    jp1
    kr
    la1
    la2
    na1
    oc1
    tr1
    ru
    sg2
    tw2
    vn2
}

model User {
    id            String  @id @map("_id")
    name          String
    email         String  @unique
    emailVerified Boolean @default(false)
    image         String?

    profileIconId Int         @default(0)
    puuid         String      @default("")
    gameName      String      @default("")
    tagLine       String      @default("")
    platform      Platform    @default(eun1)
    region        Region      @default(europe)
    lastUpdatedAt Int         @default(0)
    challenges    Challenge[]
    xp            Int         @default(0) // 5 * level^3 + 50 * level^2 + 150 * level
    level         Int         @default(1)

    createdAt DateTime  @default(now())
    updatedAt DateTime  @updatedAt
    sessions  Session[]
    accounts  Account[]

    @@map("user")
}

model Match {
    id               String @id @default(auto()) @map("_id") @db.ObjectId
    matchId          String
    gameEndTimestamp Int
    data             Json

    @@index([matchId])
    @@map("match")
}

enum ChallengeMode {
    daily
    weekly
}

model Challenge {
    id     String @id @default(auto()) @map("_id") @db.ObjectId
    userId String
    user   User   @relation(fields: [userId], references: [id])

    challengeId String
    fromTime    Int
    toTime      Int
    progress    Int     @default(0)
    collectable Boolean @default(false)
    completed   Boolean @default(false)

    @@map("challenge")
}

model Session {
    id        String   @id @map("_id")
    expiresAt DateTime
    token     String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    ipAddress String?
    userAgent String?
    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([token])
    @@index([userId])
    @@map("session")
}

model Account {
    id                    String    @id @map("_id")
    accountId             String
    providerId            String
    userId                String
    user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    accessToken           String?
    refreshToken          String?
    idToken               String?
    accessTokenExpiresAt  DateTime?
    refreshTokenExpiresAt DateTime?
    scope                 String?
    password              String?
    createdAt             DateTime  @default(now())
    updatedAt             DateTime  @updatedAt

    @@index([userId])
    @@map("account")
}
